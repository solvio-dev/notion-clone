{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "デフォルト権限設定",
  "windows": [
    "main"
  ],
  "permissions": [
    "core:default",
    "sql:default",
    "sql:allow-execute",
    "sql:allow-select",
    "sql:allow-close",
    "shell:default",
    "shell:allow-open",
    "shell:allow-spawn",
    "shell:allow-stdin-write",
    "shell:allow-kill",
    {
      "identifier": "shell:allow-execute",
      "allow": [
        {
          "name": "exec-shell",
          "cmd": "/bin/zsh",
          "args": true
        }
      ]
    }
  ]
}
